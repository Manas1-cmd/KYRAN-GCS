<Window x:Class="SimpleDroneGCS.SimulatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Sim_Title}"
        Width="700" Height="480"
        MinWidth="600" MinHeight="420"
        Background="#060B1A"
        Foreground="#C8D8E8"
        WindowStartupLocation="CenterOwner"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- Toolbar button style -->
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="10,4"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox style matching theme -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"        Value="#0D1733"/>
            <Setter Property="Foreground"        Value="#C8D8E8"/>
            <Setter Property="BorderBrush"       Value="#2A4361"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Padding"           Value="6,3"/>
            <Setter Property="FontSize"          Value="12"/>
        </Style>

        <!-- Log item style -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C8D8E8"/>
            <Setter Property="Padding"    Value="0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <!-- toolbar -->
            <RowDefinition Height="*"/>
            <!-- main content -->
            <RowDefinition Height="145"/>
            <!-- log -->
        </Grid.RowDefinitions>

        <!-- ═══ Toolbar ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#0D1733"
                BorderBrush="#2A4361" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="10,0" VerticalAlignment="Center">

                <!-- Start / Stop -->
                <Button x:Name="StartStopBtn"
                        Style="{StaticResource ToolBtn}"
                        Content="{DynamicResource Sim_BtnStart}"
                        Foreground="#98F019" BorderBrush="#98F019"
                        FontWeight="Medium"
                        Click="StartStopBtn_Click"
                        Margin="0,0,10,0"/>

                <!-- Vehicle type -->
                <ComboBox x:Name="VehicleTypeCombo" Width="160" Margin="0,0,10,0"
                          SelectionChanged="VehicleTypeCombo_SelectionChanged" Foreground="#0D1733" >
                    <ComboBoxItem Content="{DynamicResource Sim_VehicleCopter}" IsSelected="True"/>
                    <ComboBoxItem Content="{DynamicResource Sim_VehicleVtol}" IsEnabled="False"
                                  />
                </ComboBox>

                <!-- Scenario -->
                <TextBlock Text="{DynamicResource Sim_ScenarioLabel}" Foreground="#4A6080" FontSize="11"
                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox x:Name="ScenarioCombo" Width="150" Margin="0,0,10,0" 
                          SelectionChanged="ScenarioCombo_SelectionChanged" Foreground="#0D1733">
                    <ComboBoxItem Content="{DynamicResource Sim_ScenarioNormal}" Tag="normal" IsSelected="True"/>
                    <ComboBoxItem Content="{DynamicResource Sim_ScenarioGpsLoss}" Tag="gps"/>
                    <ComboBoxItem Content="{DynamicResource Sim_ScenarioBatt}" Tag="batt"/>
                    <ComboBoxItem Content="{DynamicResource Sim_ScenarioRc}" Tag="rc"/>
                </ComboBox>

                <!-- Spacer -->
                <Border Width="1" Height="18" Background="#2A4361" Margin="4,0,10,0"/>

                <!-- UDP status -->
                <Ellipse x:Name="UdpDot" Width="7" Height="7" Fill="#4A6080"
                         Margin="0,0,5,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="UdpLabel" Text="{DynamicResource Sim_UdpReady}"
                           FontSize="11" Foreground="#4A6080" VerticalAlignment="Center" Margin="0,0,14,0"/>

                <!-- GCS status -->
                <Ellipse x:Name="GcsDot" Width="7" Height="7" Fill="#4A6080"
                         Margin="0,0,5,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="GcsLabel" Text="{DynamicResource Sim_GcsDisconnected}"
                           FontSize="11" Foreground="#4A6080" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ═══ Main content ══════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190"/>
                <!-- left: status -->
                <ColumnDefinition Width="1"/>
                <!-- divider -->
                <ColumnDefinition Width="*"/>
                <!-- right: center display -->
            </Grid.ColumnDefinitions>

            <!-- Left panel ─────────────────────────────────────────────────── -->
            <Border Grid.Column="0" Background="#0D1733">
                <StackPanel Margin="12,10">

                    <TextBlock Text="{DynamicResource Sim_SectionStatus}" FontSize="10" Foreground="#4A6080"
                               FontWeight="Medium" Margin="0,0,0,8"
                              />

                    <!-- Armed -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource Sim_LabelArm}" FontSize="12" Foreground="#4A6080" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Background="#1A0505" BorderBrush="#E24B4A"
                                BorderThickness="1" CornerRadius="2" Padding="6,2">
                            <TextBlock x:Name="ArmBadge" Text="{DynamicResource Sim_BadgeDisarmed}"
                                       FontSize="11" FontWeight="Medium" Foreground="#E24B4A"/>
                        </Border>
                    </Grid>

                    <!-- Mode -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource Sim_LabelMode}" FontSize="12" Foreground="#4A6080"/>
                        <TextBlock x:Name="ModeLabel" Grid.Column="1" Text="STABILIZE"
                                   FontSize="12" FontWeight="Medium" Foreground="#85B7EB"/>
                    </Grid>

                    <!-- State -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource Sim_LabelPhase}" FontSize="12" Foreground="#4A6080"/>
                        <TextBlock x:Name="StateLabel" Grid.Column="1" Text="{DynamicResource Sim_StateDisarmed}"
                                   FontSize="12" FontWeight="Medium" Foreground="#4A6080"/>
                    </Grid>

                    <!-- WP progress -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource Sim_LabelWp}" FontSize="12" Foreground="#4A6080"/>
                        <TextBlock x:Name="WpLabel" Grid.Column="1" Text="{DynamicResource Sim_WpNone}"
                                   FontSize="12" FontWeight="Medium" Foreground="#C8D8E8"/>
                    </Grid>

                    <Rectangle Height="1" Fill="#2A4361" Margin="0,6"/>

                    <TextBlock Text="{DynamicResource Sim_SectionTelemetry}" FontSize="10" Foreground="#4A6080"
                               FontWeight="Medium" Margin="0,0,0,8"/>

                    <!-- Altitude -->
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource Sim_LabelAlt}" FontSize="12" Foreground="#4A6080"/>
                        <TextBlock x:Name="AltLabel" Grid.Column="1" Text="0.0 м"
                                   FontSize="12" FontWeight="Medium" Foreground="#98F019"/>
                    </Grid>

                    <!-- Speed -->
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource Sim_LabelSpeed}" FontSize="12" Foreground="#4A6080"/>
                        <TextBlock x:Name="SpeedLabel" Grid.Column="1" Text="0.0 м/с"
                                   FontSize="12" FontWeight="Medium" Foreground="#85B7EB"/>
                    </Grid>

                    <!-- Battery -->
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource Sim_LabelBatt}" FontSize="12" Foreground="#4A6080"/>
                        <TextBlock x:Name="BattLabel" Grid.Column="1" Text="100% · 12.6В"
                                   FontSize="12" FontWeight="Medium" Foreground="#EF9F27"/>
                    </Grid>

                    <!-- GPS -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource Sim_LabelGps}" FontSize="12" Foreground="#4A6080"/>
                        <TextBlock x:Name="GpsLabel" Grid.Column="1" Text="3D Fix (12)"
                                   FontSize="12" FontWeight="Medium" Foreground="#98F019"/>
                    </Grid>

                    <Rectangle Height="1" Fill="#2A4361" Margin="0,6"/>

                    <!-- Speed slider -->
                    <TextBlock Text="{DynamicResource Sim_SectionCruiseSpeed}" FontSize="10" Foreground="#4A6080"
                               FontWeight="Medium" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="SpeedSlider" Minimum="2" Maximum="15" Value="8"
                                IsSnapToTickEnabled="True" TickFrequency="1"
                                Foreground="#98F019"
                                ValueChanged="SpeedSlider_ValueChanged"/>
                        <TextBlock x:Name="SpeedSliderLabel" Grid.Column="1"
                                   Text="8 м/с" FontSize="11" Foreground="#C8D8E8"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Divider -->
            <Rectangle Grid.Column="1" Fill="#2A4361"/>

            <!-- Right panel: clock + state visualization ────────────────────── -->
            <Grid Grid.Column="2" Background="#060B1A">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="SimStatusBig" Text="{DynamicResource Sim_StatusStopped}"
                               FontSize="13" Foreground="#2A4361" FontWeight="Medium"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="FlightTimeTxt" Text="00:00:00"
                               FontSize="46" Foreground="#2A4361"
                               HorizontalAlignment="Center"
                               FontFamily="Consolas" Margin="0,6,0,4"/>
                    <TextBlock Text="{DynamicResource Sim_FlightTimeLabel}" FontSize="10" Foreground="#2A4361"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="HomeCoordsTxt"
                               Text="HOME: 43.2389°N  76.8897°E"
                               FontSize="11" Foreground="#2A4361"
                               HorizontalAlignment="Center" Margin="0,16,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ═══ Log panel ═════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#0D1733"
                BorderBrush="#2A4361" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="22"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="12,2">
                    <TextBlock Text="{DynamicResource Sim_LogTitle}" FontSize="10" Foreground="#4A6080"
                               FontWeight="Medium" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource Sim_LogSubtitle}" FontSize="10"
                               Foreground="#2A4361" VerticalAlignment="Center"/>
                </StackPanel>

                <ListBox x:Name="LogList" Grid.Row="1"
                         Background="Transparent" BorderThickness="0"
                         Margin="8,0,4,4"
                         FontFamily="Consolas" FontSize="11"
                         Foreground="#C8D8E8"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"/>
            </Grid>
        </Border>
    </Grid>
</Window>