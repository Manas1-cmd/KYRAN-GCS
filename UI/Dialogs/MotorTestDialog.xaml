<Window x:Class="SimpleDroneGCS.UI.Dialogs.MotorTestDialog"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		Title="Motor Test"
		Width="560" Height="720"
		WindowStyle="None"
		AllowsTransparency="True"
		Background="Transparent"
		ResizeMode="NoResize"
		WindowStartupLocation="CenterOwner"
		ShowInTaskbar="False"
		KeyDown="Window_KeyDown">

	<Window.Resources>
		<ControlTemplate x:Key="FlatBtn" TargetType="Button">
			<Border x:Name="Bd"
					Background="{TemplateBinding Background}"
					BorderBrush="{TemplateBinding BorderBrush}"
					BorderThickness="{TemplateBinding BorderThickness}"
					CornerRadius="6">
				<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
								  Margin="{TemplateBinding Padding}"/>
			</Border>
			<ControlTemplate.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
				</Trigger>
				<Trigger Property="IsEnabled" Value="False">
					<Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
				</Trigger>
			</ControlTemplate.Triggers>
		</ControlTemplate>

		<!-- Стиль кнопки выбора конфигурации -->
		<Style x:Key="ConfigBtnStyle" TargetType="Button">
			<Setter Property="Height" Value="28"/>
			<Setter Property="FontFamily" Value="Consolas"/>
			<Setter Property="FontSize" Value="11"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="BorderThickness" Value="1.5"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="Bd"
								Background="{TemplateBinding Background}"
								BorderBrush="{TemplateBinding BorderBrush}"
								BorderThickness="{TemplateBinding BorderThickness}"
								CornerRadius="6">
							<ContentPresenter HorizontalAlignment="Center"
											  VerticalAlignment="Center"
											  Margin="{TemplateBinding Padding}"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</Window.Resources>

	<Border Background="#060B1A"
			BorderBrush="#2A4361"
			BorderThickness="1.5"
			CornerRadius="12">

		<Grid Margin="24,20,24,20">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<!-- Заголовок -->
			<StackPanel Grid.Row="0" HorizontalAlignment="Center">
				<TextBlock Text="{DynamicResource MotorTest_Title}"
						   FontSize="16" FontWeight="Bold" FontFamily="Consolas"
						   Foreground="#98F019" HorizontalAlignment="Center"/>
				<TextBlock Text="{DynamicResource MotorTest_Subtitle}"
						   FontSize="10" FontFamily="Consolas"
						   Foreground="#4498F019" HorizontalAlignment="Center"
						   Margin="0,2,0,0"/>
			</StackPanel>

			<!-- Предупреждение -->
			<Border Grid.Row="1" Background="#1C0A0A" BorderBrush="#7F1D1D"
					BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,12,0,0">
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
					<TextBlock Text="⚠  " Foreground="#EF4444" FontSize="13" FontWeight="Bold"
							   VerticalAlignment="Center"/>
					<TextBlock Text="{DynamicResource MotorTest_Warning}"
							   Foreground="#EF4444" FontFamily="Consolas" FontSize="11"
							   FontWeight="Bold" VerticalAlignment="Center"/>
				</StackPanel>
			</Border>

			<!-- Статус ARMED -->
			<Border Grid.Row="2" x:Name="ArmedWarningBorder"
					Background="#1C0A0A" BorderBrush="#EF4444"
					BorderThickness="1" CornerRadius="8" Padding="10,6"
					Margin="0,8,0,0" Visibility="Collapsed">
				<TextBlock Text="{DynamicResource MotorTest_ArmedWarning}"
						   Foreground="#EF4444" FontFamily="Consolas" FontSize="11"
						   HorizontalAlignment="Center" FontWeight="Bold"/>
			</Border>

			<!-- Селектор конфигурации (только для мультикоптера) -->
			<Border Grid.Row="3" x:Name="ConfigSelectorRow"
					Background="#0D1733" CornerRadius="8" Padding="12,8"
					Margin="0,8,0,0" Visibility="Collapsed">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>

					<TextBlock Grid.Column="0"
							   Text="{DynamicResource MotorTest_Config}"
							   FontFamily="Consolas" FontSize="10"
							   Foreground="#6B7280" VerticalAlignment="Center"
							   Margin="0,0,12,0"/>

					<StackPanel Grid.Column="1" Orientation="Horizontal">
						<Button x:Name="Cfg4Btn" Content="4"
								Width="48" Padding="0"
								Margin="0,0,6,0"
								Style="{StaticResource ConfigBtnStyle}"
								Click="CfgBtn_Click" Tag="4"/>
						<Button x:Name="Cfg6Btn" Content="6"
								Width="48" Padding="0"
								Margin="0,0,6,0"
								Style="{StaticResource ConfigBtnStyle}"
								Click="CfgBtn_Click" Tag="6"/>
						<Button x:Name="Cfg8Btn" Content="8"
								Width="48" Padding="0"
								Style="{StaticResource ConfigBtnStyle}"
								Click="CfgBtn_Click" Tag="8"/>
					</StackPanel>
				</Grid>
			</Border>

			<!-- Разделитель -->
			<Rectangle Grid.Row="4" Height="1" Fill="#1A2A4361" Margin="0,10,0,0"/>

			<!-- Основной контент -->
			<Grid Grid.Row="5" Margin="0,12,0,0">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>

				<!-- Слайдеры -->
				<Grid Grid.Row="0" Margin="0,0,0,16">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="16"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>

					<Border Grid.Column="0" Background="#0D1733" CornerRadius="8" Padding="12,10">
						<StackPanel>
							<TextBlock Text="{DynamicResource MotorTest_Throttle}"
									   FontFamily="Consolas" FontSize="10"
									   Foreground="#6B7280" Margin="0,0,0,4"/>
							<StackPanel Orientation="Horizontal">
								<TextBlock x:Name="ThrottleValueText"
										   Text="5%" FontFamily="Consolas" FontSize="20"
										   FontWeight="Bold" Foreground="#98F019"
										   VerticalAlignment="Center" Width="50"/>
								<TextBlock Text="{DynamicResource MotorTest_ThrottleRange}"
										   FontFamily="Consolas" FontSize="9"
										   Foreground="#4B5563" VerticalAlignment="Bottom"
										   Margin="4,0,0,2"/>
							</StackPanel>
							<Slider x:Name="ThrottleSlider"
									Minimum="5" Maximum="30" Value="5"
									TickFrequency="5" IsSnapToTickEnabled="True"
									Margin="0,6,0,0"
									ValueChanged="ThrottleSlider_ValueChanged"/>
						</StackPanel>
					</Border>

					<Border Grid.Column="2" Background="#0D1733" CornerRadius="8" Padding="12,10">
						<StackPanel>
							<TextBlock Text="{DynamicResource MotorTest_Duration}"
									   FontFamily="Consolas" FontSize="10"
									   Foreground="#6B7280" Margin="0,0,0,4"/>
							<StackPanel Orientation="Horizontal">
								<TextBlock x:Name="DurationValueText"
										   Text="2с" FontFamily="Consolas" FontSize="20"
										   FontWeight="Bold" Foreground="#60A5FA"
										   VerticalAlignment="Center" Width="40"/>
								<TextBlock Text="{DynamicResource MotorTest_DurationRange}"
										   FontFamily="Consolas" FontSize="9"
										   Foreground="#4B5563" VerticalAlignment="Bottom"
										   Margin="4,0,0,2"/>
							</StackPanel>
							<Slider x:Name="DurationSlider"
									Minimum="1" Maximum="5" Value="2"
									TickFrequency="1" IsSnapToTickEnabled="True"
									Margin="0,6,0,0"
									ValueChanged="DurationSlider_ValueChanged"/>
						</StackPanel>
					</Border>
				</Grid>

				<!-- Схема моторов -->
				<Border Grid.Row="1" Background="#0D1733" CornerRadius="8" Padding="16,12"
						Margin="0,0,0,16">
					<StackPanel>
						<TextBlock x:Name="LayoutLabel"
								   Text="{DynamicResource MotorTest_Layout}"
								   FontFamily="Consolas" FontSize="10"
								   Foreground="#6B7280" HorizontalAlignment="Center"
								   Margin="0,0,0,10"/>

						<Grid x:Name="MotorLayoutGrid" Width="260" Height="190"
							  HorizontalAlignment="Center">

							<!-- Центр дрона -->
							<Ellipse Width="36" Height="36"
									 Fill="#0A0F1E" Stroke="#2A4361"
									 StrokeThickness="1.5"
									 HorizontalAlignment="Center"
									 VerticalAlignment="Center"/>
							<TextBlock x:Name="DroneIcon"
									   Text="+" Foreground="#4B5563" FontSize="20"
									   FontWeight="Bold"
									   HorizontalAlignment="Center"
									   VerticalAlignment="Center"/>

							<!-- Линии арм строятся из code-behind -->
							<Canvas x:Name="ArmLinesCanvas"/>

							<!-- Кнопки моторов -->
							<Canvas x:Name="MotorButtonsCanvas"/>
						</Grid>

						<!-- Pusher (только VTOL) -->
						<Border x:Name="PusherRow"
								Background="#060B1A" CornerRadius="6" Padding="10,6"
								Margin="0,8,0,0" Visibility="Collapsed">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<TextBlock Text="{DynamicResource MotorTest_Pusher}"
										   FontFamily="Consolas" FontSize="11"
										   Foreground="#94A3B8" VerticalAlignment="Center"/>
								<Button x:Name="PusherBtn" Grid.Column="1"
										Width="100" Height="32"
										FontFamily="Consolas" FontSize="11"
										Background="#0D1733" Foreground="#94A3B8"
										BorderBrush="#2A4361" BorderThickness="1"
										Cursor="Hand"
										Template="{StaticResource FlatBtn}"
										Click="MotorBtn_Click" Tag="5"/>
							</Grid>
						</Border>
					</StackPanel>
				</Border>

				<!-- Лог статуса -->
				<Border Grid.Row="2" Background="#0D1733" CornerRadius="8" Padding="10,8">
					<ScrollViewer x:Name="StatusScroll"
								  VerticalScrollBarVisibility="Auto"
								  MaxHeight="70">
						<StackPanel x:Name="StatusLog"/>
					</ScrollViewer>
				</Border>
			</Grid>

			<!-- Test All + Stop -->
			<Grid Grid.Row="6" Margin="0,12,0,0">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="8"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>

				<Button x:Name="TestAllBtn" Grid.Column="0"
						Content="{DynamicResource MotorTest_TestAll}"
						Height="38" FontFamily="Consolas" FontSize="12" FontWeight="Bold"
						Background="#0D2B1A" Foreground="#98F019"
						BorderBrush="#166534" BorderThickness="1"
						Cursor="Hand" Click="TestAllBtn_Click"
						Template="{StaticResource FlatBtn}"/>

				<Button x:Name="StopBtn" Grid.Column="2"
						Content="{DynamicResource MotorTest_Stop}"
						Height="38" FontFamily="Consolas" FontSize="12" FontWeight="Bold"
						Background="#1C0A0A" Foreground="#EF4444"
						BorderBrush="#7F1D1D" BorderThickness="1"
						Cursor="Hand" Click="StopBtn_Click"
						Template="{StaticResource FlatBtn}"/>
			</Grid>

			<!-- Закрыть -->
			<Button Grid.Row="7" x:Name="CloseBtn"
					Content="{DynamicResource MotorTest_Close}"
					Height="36" FontFamily="Consolas" FontSize="12"
					Background="#0D1733" Foreground="#6B7280"
					BorderBrush="#2A4361" BorderThickness="1"
					Cursor="Hand" Click="CloseBtn_Click"
					Template="{StaticResource FlatBtn}"
					Margin="0,8,0,0"/>
		</Grid>
	</Border>
</Window>