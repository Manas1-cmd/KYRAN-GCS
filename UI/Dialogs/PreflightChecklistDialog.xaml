<Window x:Class="SimpleDroneGCS.UI.Dialogs.PreflightChecklistDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preflight Checklist"
        Width="520" Height="640"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <ControlTemplate x:Key="FlatBtn" TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Margin="{TemplateBinding Padding}"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Window.Resources>

    <Border Background="#060B1A"
            BorderBrush="#2A4361"
            BorderThickness="1.5"
            CornerRadius="12">

        <Grid Margin="24,20,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="{DynamicResource Preflight_Title}"
                           FontSize="16" FontWeight="Bold" FontFamily="Consolas"
                           Foreground="#98F019" HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource Preflight_Subtitle}"
                           FontSize="10" FontFamily="Consolas"
                           Foreground="#4498F019" HorizontalAlignment="Center"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Разделитель -->
            <Rectangle Grid.Row="1" Height="1" Fill="#1A2A4361" Margin="0,10,0,10"/>

            <!-- Строки проверок строятся из code-behind -->
            <StackPanel Grid.Row="2" x:Name="ChecklistPanel"/>

            <!-- Итоговый статус -->
            <Border Grid.Row="3" x:Name="StatusBorder"
                    Background="#0D1733" CornerRadius="8" Padding="12,8"
                    BorderThickness="1" Margin="0,10,0,0">
                <TextBlock x:Name="StatusText"
                           FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- Кнопки -->
            <Grid Grid.Row="4" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="CancelBtn" Grid.Column="0"
                        Content="{DynamicResource Preflight_Cancel}"
                        Height="38" FontFamily="Consolas" FontSize="12"
                        Background="#0D1733" Foreground="#6B7280"
                        BorderBrush="#2A4361" BorderThickness="1"
                        Cursor="Hand" Click="CancelBtn_Click"
                        Template="{StaticResource FlatBtn}"/>

                <Button x:Name="RefreshBtn" Grid.Column="2"
                        Content="{DynamicResource Preflight_Refresh}"
                        Height="38" FontFamily="Consolas" FontSize="12"
                        Background="#0D1733" Foreground="#98F019"
                        BorderBrush="#2A4361" BorderThickness="1"
                        Cursor="Hand" Click="RefreshBtn_Click"
                        Template="{StaticResource FlatBtn}"/>

                <!-- Видна только если критичные проверки провалены -->
                <Button x:Name="ForceArmBtn" Grid.Column="4"
                        Content="{DynamicResource Preflight_ForceArm}"
                        Height="38" Padding="10,0"
                        FontFamily="Consolas" FontSize="11"
                        Background="#1C0A0A" Foreground="#EF4444"
                        BorderBrush="#7F1D1D" BorderThickness="1"
                        Cursor="Hand" Click="ForceArmBtn_Click"
                        Visibility="Collapsed"
                        Template="{StaticResource FlatBtn}"/>

                <Button x:Name="ArmBtn" Grid.Column="6"
                        Content="{DynamicResource Preflight_Arm}"
                        Height="38" FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                        Background="#166534" Foreground="#98F019"
                        BorderBrush="#22C55E" BorderThickness="1"
                        Cursor="Hand" Click="ArmBtn_Click" IsEnabled="False"
                        Template="{StaticResource FlatBtn}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
