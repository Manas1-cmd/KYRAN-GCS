<Window x:Class="SimpleDroneGCS.Simulator.SimulatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Симулятор SQK GCS"
        Height="720" Width="820"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A1A"
        Foreground="#E0E0E0"
        FontFamily="Segoe UI"
        FontSize="12"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <!-- Общие стили -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="BorderBrush" Value="#3D3D3D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#4D4D4D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4D4D4D"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StartButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#22C55E"/>
            <Setter Property="BorderBrush" Value="#16A34A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="StopButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="BorderBrush" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="PauseButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#F59E0B"/>
            <Setter Property="BorderBrush" Value="#D97706"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="FailureButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="HudLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="HudValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3D3D3D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <Style x:Key="SimRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ==================== Верхний ряд: Управление + HUD + Ветер ==================== -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Управление -->
            <Border Grid.Column="0" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="УПРАВЛЕНИЕ" Style="{StaticResource SectionHeader}"/>

                    <Button x:Name="StartBtn" Content="▶  Запустить"
                            Style="{StaticResource StartButton}"
                            Click="StartBtn_Click"/>
                    <Button x:Name="StopBtn" Content="■  Остановить"
                            Style="{StaticResource StopButton}"
                            Click="StopBtn_Click" IsEnabled="False"/>
                    <Button x:Name="PauseBtn" Content="⏸  Пауза"
                            Style="{StaticResource PauseButton}"
                            Click="PauseBtn_Click" IsEnabled="False"/>

                    <TextBlock Text="СКОРОСТЬ ВРЕМЕНИ" Style="{StaticResource SectionHeader}"
                               Margin="0,14,0,6"/>
                    <WrapPanel>
                        <RadioButton x:Name="Speed05" Content="x0.5" GroupName="Speed"
                                     Style="{StaticResource SimRadio}" Margin="0,0,10,0"
                                     Checked="Speed_Checked" Tag="0.5"/>
                        <RadioButton x:Name="Speed1" Content="x1" GroupName="Speed"
                                     Style="{StaticResource SimRadio}" IsChecked="True"
                                     Margin="0,0,10,0" Checked="Speed_Checked" Tag="1"/>
                        <RadioButton x:Name="Speed2" Content="x2" GroupName="Speed"
                                     Style="{StaticResource SimRadio}" Margin="0,0,10,0"
                                     Checked="Speed_Checked" Tag="2"/>
                        <RadioButton x:Name="Speed5" Content="x5" GroupName="Speed"
                                     Style="{StaticResource SimRadio}"
                                     Checked="Speed_Checked" Tag="5"/>
                    </WrapPanel>

                    <TextBlock Text="ТИП ВС" Style="{StaticResource SectionHeader}"
                               Margin="0,14,0,6"/>
                    <RadioButton x:Name="VehCopter" Content="Мультикоптер"
                                 GroupName="Veh"
                                 Style="{StaticResource SimRadio}"
                                 Checked="Vehicle_Checked" Tag="Copter"/>
                    <RadioButton x:Name="VehVtol" Content="VTOL (QuadPlane)"
                                 GroupName="Veh" IsChecked="True"
                                 Style="{StaticResource SimRadio}"
                                 Checked="Vehicle_Checked" Tag="Vtol"/>

                    <TextBlock Text="HOME" Style="{StaticResource SectionHeader}"
                               Margin="0,14,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="55"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Lat:"
                                   VerticalAlignment="Center" Margin="0,3"
                                   Style="{StaticResource HudLabel}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="HomeLatBox"
                                 Style="{StaticResource InputBox}" Margin="0,3"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Lon:"
                                   VerticalAlignment="Center" Margin="0,3"
                                   Style="{StaticResource HudLabel}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="HomeLonBox"
                                 Style="{StaticResource InputBox}" Margin="0,3"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Alt:"
                                   VerticalAlignment="Center" Margin="0,3"
                                   Style="{StaticResource HudLabel}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="HomeAltBox"
                                 Style="{StaticResource InputBox}" Margin="0,3"/>
                    </Grid>
                    <Button Content="Применить HOME"
                            Style="{StaticResource ActionButton}"
                            Margin="0,6,0,0"
                            Click="ApplyHomeBtn_Click"/>
                </StackPanel>
            </Border>

            <!-- HUD + Wind -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource PanelStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="HUD" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Колонка 1 -->
                            <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Lat:  " Style="{StaticResource HudLabel}" Width="50"/>
                                <TextBlock x:Name="HudLat" Text="—" Style="{StaticResource HudValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="0" Grid.Row="1" Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Lon:  " Style="{StaticResource HudLabel}" Width="50"/>
                                <TextBlock x:Name="HudLon" Text="—" Style="{StaticResource HudValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="0" Grid.Row="2" Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Alt:  " Style="{StaticResource HudLabel}" Width="50"/>
                                <TextBlock x:Name="HudAlt" Text="—" Style="{StaticResource HudValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="0" Grid.Row="3" Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="GS:   " Style="{StaticResource HudLabel}" Width="50"/>
                                <TextBlock x:Name="HudGs" Text="—" Style="{StaticResource HudValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="0" Grid.Row="4" Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="AS:   " Style="{StaticResource HudLabel}" Width="50"/>
                                <TextBlock x:Name="HudAs" Text="—" Style="{StaticResource HudValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="0" Grid.Row="5" Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Курс: " Style="{StaticResource HudLabel}" Width="50"/>
                                <TextBlock x:Name="HudHdg" Text="—" Style="{StaticResource HudValue}"/>
                            </StackPanel>

                            <!-- Колонка 2 -->
                            <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Крен: " Style="{StaticResource HudLabel}" Width="60"/>
                                <TextBlock x:Name="HudRoll" Text="—" Style="{StaticResource HudValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Танг.:" Style="{StaticResource HudLabel}" Width="60"/>
                                <TextBlock x:Name="HudPitch" Text="—" Style="{StaticResource HudValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Бат.: " Style="{StaticResource HudLabel}" Width="60"/>
                                <TextBlock x:Name="HudBatt" Text="—" Style="{StaticResource HudValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="3" Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Режим:" Style="{StaticResource HudLabel}" Width="60"/>
                                <TextBlock x:Name="HudMode" Text="—" Style="{StaticResource HudValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="4" Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="ARM:  " Style="{StaticResource HudLabel}" Width="60"/>
                                <TextBlock x:Name="HudArm" Text="—" Style="{StaticResource HudValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="5" Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="GCS:  " Style="{StaticResource HudLabel}" Width="60"/>
                                <TextBlock x:Name="HudGcs" Text="Не подкл." Style="{StaticResource HudValue}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Ветер -->
                <Border Grid.Row="1" Style="{StaticResource PanelStyle}">
                    <StackPanel>
                        <TextBlock Text="ВЕТЕР" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Направл.:"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource HudLabel}"/>
                            <Slider Grid.Row="0" Grid.Column="1" x:Name="WindDirSlider"
                                    Minimum="0" Maximum="359" Value="0"
                                    TickFrequency="45" IsSnapToTickEnabled="False"
                                    ValueChanged="Wind_ValueChanged"
                                    VerticalAlignment="Center" Margin="5,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" x:Name="WindDirLabel"
                                       Text="0°" Style="{StaticResource HudValue}"
                                       VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Скорость:"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource HudLabel}"/>
                            <Slider Grid.Row="1" Grid.Column="1" x:Name="WindSpeedSlider"
                                    Minimum="0" Maximum="20" Value="0"
                                    TickFrequency="2" IsSnapToTickEnabled="False"
                                    ValueChanged="Wind_ValueChanged"
                                    VerticalAlignment="Center" Margin="5,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" x:Name="WindSpeedLabel"
                                       Text="0.0 м/с" Style="{StaticResource HudValue}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ==================== Сценарии отказов ==================== -->
        <Border Grid.Row="1" Style="{StaticResource PanelStyle}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="СЦЕНАРИИ ОТКАЗОВ" Style="{StaticResource SectionHeader}"/>
                <WrapPanel>
                    <Button x:Name="FailGps" Content="GPS Loss"
                            Style="{StaticResource FailureButton}" Tag="False"
                            Click="FailureToggle_Click"/>
                    <Button x:Name="FailRc" Content="RC Failsafe"
                            Style="{StaticResource FailureButton}" Tag="False"
                            Click="FailureToggle_Click"/>
                    <Button x:Name="FailBattLow" Content="Battery Low"
                            Style="{StaticResource FailureButton}" Tag="False"
                            Click="FailureToggle_Click"/>
                    <Button x:Name="FailBattCrit" Content="Battery Crit"
                            Style="{StaticResource FailureButton}" Tag="False"
                            Click="FailureToggle_Click"/>
                    <Button x:Name="FailCompass" Content="Compass Error"
                            Style="{StaticResource FailureButton}" Tag="False"
                            Click="FailureToggle_Click"/>
                    <Button x:Name="FailEkf" Content="EKF Diverge"
                            Style="{StaticResource FailureButton}" Tag="False"
                            Click="FailureToggle_Click"/>
                </WrapPanel>
                <WrapPanel Margin="0,4,0,0">
                    <Button x:Name="FailMotor1" Content="Motor 1"
                            Style="{StaticResource FailureButton}" Tag="False"
                            Click="MotorFailure_Click"/>
                    <Button x:Name="FailMotor2" Content="Motor 2"
                            Style="{StaticResource FailureButton}" Tag="False"
                            Click="MotorFailure_Click"/>
                    <Button x:Name="FailMotor3" Content="Motor 3"
                            Style="{StaticResource FailureButton}" Tag="False"
                            Click="MotorFailure_Click"/>
                    <Button x:Name="FailMotor4" Content="Motor 4"
                            Style="{StaticResource FailureButton}" Tag="False"
                            Click="MotorFailure_Click"/>
                    <Button x:Name="FailMotor5" Content="M5 (Pusher)"
                            Style="{StaticResource FailureButton}" Tag="False"
                            Click="MotorFailure_Click"/>
                    <Button Content="Сбросить всё"
                            Style="{StaticResource ActionButton}"
                            Margin="12,3,3,3" Padding="10,4"
                            Click="ClearAllFailures_Click"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- ==================== Лог ==================== -->
        <Border Grid.Row="2" Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="ЛОГ СОБЫТИЙ"
                               Style="{StaticResource SectionHeader}"/>
                    <Button Grid.Column="1" Content="Очистить"
                            Style="{StaticResource ActionButton}"
                            Click="ClearLog_Click" Padding="8,2"/>
                </Grid>

                <ListBox Grid.Row="1" x:Name="LogList"
                         Background="#1A1A1A"
                         Foreground="#D0D0D0"
                         BorderBrush="#3D3D3D"
                         BorderThickness="1"
                         FontFamily="Consolas" FontSize="11"
                         Margin="0,4,0,0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="4,1"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</Window>