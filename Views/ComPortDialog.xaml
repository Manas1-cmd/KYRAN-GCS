<Window x:Class="SimpleDroneGCS.Views.ComPortDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="COM подключение"
        Width="400" Height="320"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <ControlTemplate x:Key="DarkComboBoxToggle" TargetType="{x:Type ToggleButton}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="30"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2"
                        Background="#060B1A" BorderBrush="#2A4361" BorderThickness="1" CornerRadius="4"/>
                <Path Grid.Column="1"
                      Fill="#98F019" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M 0 0 L 5 5 L 10 0 Z"/>
            </Grid>
        </ControlTemplate>

        <Style x:Key="DarkComboBox" TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton Template="{StaticResource DarkComboBoxToggle}"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="10,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <TextBox x:Name="PART_EditableTextBox" Visibility="Hidden"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"
                                     Background="Transparent" Foreground="White" CaretBrush="White"
                                     FontSize="14" Margin="10,0,30,0"
                                     VerticalAlignment="Center" BorderThickness="0"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#0D1733" BorderBrush="#2A4361"
                                            BorderThickness="1" CornerRadius="4"/>
                                    <ScrollViewer Margin="2">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#1E3A5F"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A4361"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#0D1733" 
            BorderBrush="#2A4361" 
            BorderThickness="2" 
            CornerRadius="10">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="COM подключение" 
                           FontSize="18" FontWeight="Bold" Foreground="White"/>
                <Button Content="✕" HorizontalAlignment="Right"
                        Background="Transparent" Foreground="#EF4444"
                        BorderThickness="0" FontSize="16" Cursor="Hand"
                        Click="CloseButton_Click"/>
            </Grid>

            <StackPanel Grid.Row="1" VerticalAlignment="Top">
                <TextBlock Text="COM порт" Foreground="#98F019" FontSize="11" 
                           FontWeight="Bold" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="ComPortComboBox" Style="{StaticResource DarkComboBox}"/>
                    <Button Content="⟳" Grid.Column="1"
                            Width="38" Height="38"
                            Background="#1E3A5F" Foreground="#98F019"
                            BorderThickness="0" FontSize="18"
                            Margin="8,0,0,0" Cursor="Hand"
                            ToolTip="Обновить список портов"
                            Click="RefreshPorts_Click"/>
                </Grid>

                <TextBlock Text="Baud Rate" Foreground="#98F019" FontSize="11" 
                           FontWeight="Bold" Margin="0,0,0,6"/>
                <ComboBox x:Name="BaudRateComboBox" Style="{StaticResource DarkComboBox}" Margin="0,0,0,16"/>

                <TextBlock Foreground="#6B7280" FontSize="11" TextWrapping="Wrap">
                    <Run Text="SITL: используйте UDP подключение."/>
                    <LineBreak/>
                    <Run Text="Реальный дрон: COM через USB-телеметрию."/>
                </TextBlock>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" 
                        HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Отмена" Width="100" Height="38"
                        Background="#2A4361" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"
                        Click="CancelButton_Click"/>
                <Button Content="Подключить" Width="130" Height="38"
                        Background="#98F019" Foreground="#060B1A"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                        Click="ConnectButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
