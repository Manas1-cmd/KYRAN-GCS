<Window x:Class="SimpleDroneGCS.Views.CameraConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource CamConn_Title}"
        Height="420" Width="450"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border Background="#0D1733" CornerRadius="12" BorderThickness="2" BorderBrush="#2A4361">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="#0A1628" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="15,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📹" FontSize="16" Margin="0,0,10,0"/>
                        <TextBlock Text="{DynamicResource CamConn_Header}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right"
                            Width="30" Height="30"
                            Background="Transparent" Foreground="#EF4444"
                            BorderThickness="0" FontSize="14"
                            Click="CloseButton_Click" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- Поля -->
            <StackPanel Grid.Row="1" Margin="25,20">

                <!-- Инфо о камере -->
                <Border Background="#0A1628" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="ViewPro A40TR Pro"
                                   Foreground="#98F019" FontSize="13" FontWeight="SemiBold"
                                   FontFamily="Consolas"/>
                        <TextBlock Text="40x EO  |  IR 640×512  |  LRF 3000м  |  AI Tracking"
                                   Foreground="#6677AA" FontSize="11" Margin="0,4,0,0"
                                   FontFamily="Consolas"/>
                    </StackPanel>
                </Border>

                <!-- IP -->
                <TextBlock Text="{DynamicResource CamConn_IP}"
                           Foreground="#9CA3AF" FontSize="12" Margin="0,0,0,6"/>
                <TextBox x:Name="IpAddressTextBox" Height="36"
                         Text="192.168.2.119"
                         Background="#1A2744" Foreground="White"
                         BorderBrush="#2A4361" FontSize="14"
                         Padding="10,8" VerticalContentAlignment="Center"
                         TextChanged="IpAddress_TextChanged"/>

                <!-- TCP / RTSP порты -->
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{DynamicResource CamConn_TCPPort}"
                                   Foreground="#9CA3AF" FontSize="12" Margin="0,0,0,6"/>
                        <TextBox x:Name="TcpPortTextBox" Height="36"
                                 Text="2000"
                                 Background="#1A2744" Foreground="White"
                                 BorderBrush="#2A4361" FontSize="14"
                                 Padding="10,8" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{DynamicResource CamConn_RTSPPort}"
                                   Foreground="#9CA3AF" FontSize="12" Margin="0,0,0,6"/>
                        <TextBox x:Name="RtspPortTextBox" Height="36"
                                 Text="554"
                                 Background="#1A2744" Foreground="White"
                                 BorderBrush="#2A4361" FontSize="14"
                                 Padding="10,8" VerticalContentAlignment="Center"
                                 TextChanged="RtspPort_TextChanged"/>
                    </StackPanel>
                </Grid>

                <!-- RTSP URL -->
                <TextBlock Text="{DynamicResource CamConn_RTSPUrl}"
                           Foreground="#9CA3AF" FontSize="12" Margin="0,12,0,6"/>
                <TextBox x:Name="RtspUrlTextBox" Height="36"
                         Text="rtsp://192.168.2.119:554"
                         Background="#1A2744" Foreground="White"
                         BorderBrush="#2A4361" FontSize="12"
                         Padding="10,8" VerticalContentAlignment="Center"
                         IsReadOnly="True"/>

            </StackPanel>

            <!-- Кнопки -->
            <Border Grid.Row="2" Background="#0A1628" CornerRadius="0,0,12,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,0">
                    <Button x:Name="CancelButton" Content="{DynamicResource Cancel}"
                            Width="100" Height="36"
                            Background="#374151" Foreground="White"
                            BorderThickness="0" FontSize="13"
                            Click="CancelButton_Click" Cursor="Hand" Margin="0,0,10,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="ConnectButton" Content="{DynamicResource CamConn_Connect}"
                            Width="130" Height="36"
                            Background="#98F019" Foreground="#060B1A"
                            BorderThickness="0" FontSize="13" FontWeight="SemiBold"
                            Click="ConnectButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#7ACC0E"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
